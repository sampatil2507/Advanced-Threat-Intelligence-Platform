# Copy this to .env and fill your values.
# NEVER commit your real .env to GitHub!

# MongoDB — default works if MongoDB is running locally
MONGO_URI=mongodb://localhost:27017/

# Set to true ONLY on Linux as root (for real iptables)
ENFORCE_REAL_FIREWALL=false

# Optional — project works WITHOUT these (uses fallback IPs)
OTX_API_KEY=your_key_here
ABUSEIPDB_API_KEY=your_key_here
