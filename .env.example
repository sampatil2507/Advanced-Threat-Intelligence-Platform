# ─────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file — it's in .gitignore.
# ─────────────────────────────────────────────────────────────

# MongoDB (default works if MongoDB is installed locally)
MONGO_URI=mongodb://localhost:27017/

# Set to "true" ONLY if running as root on Linux with iptables
# Leave as "false" for safe simulation mode (Windows/Mac/testing)
ENFORCE_REAL_FIREWALL=false

# Optional API Keys — project works without these (uses fallback data)
OTX_API_KEY=your_alienvault_otx_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here
